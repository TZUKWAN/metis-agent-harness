{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metis.local/schemas/evals/suite-schema-v1.json",
  "title": "Metis Eval Suite Schema v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "tasks"],
  "properties": {
    "suite": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "profile": {
      "type": "string"
    },
    "baseline": {
      "type": "object"
    },
    "current": {
      "type": "object"
    },
    "task_count": {
      "type": "integer",
      "minimum": 0
    },
    "artifact_path_diagnostic_summary": {
      "type": "object"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/wrapped_task_entry"
          },
          {
            "$ref": "#/$defs/eval_task_spec"
          }
        ]
      }
    }
  },
  "$defs": {
    "wrapped_task_entry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["task_spec"],
      "properties": {
        "task_id": {
          "type": "string"
        },
        "source_repair_task_id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "priority": {
          "type": "string"
        },
        "owner_area": {
          "type": "string"
        },
        "cluster_keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "critical_event_ids": {
          "type": "object"
        },
        "run_metadata": {
          "type": "object"
        },
        "stub_type": {
          "type": "string"
        },
        "trust_state": {
          "type": "object"
        },
        "target_runs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "quality_gate_changes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "quality_gate_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifact_path_diagnostics": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "schema_repair_hint_events": {
          "type": "object"
        },
        "schema_repair_hint_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "schema_repair_argument_templates": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "tool_schemas": {
          "type": "object",
          "additionalProperties": {
            "type": "object"
          }
        },
        "likely_source_modules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "suggested_assertion": {
          "type": "string"
        },
        "verification_command": {
          "type": "string"
        },
        "task_spec": {
          "$ref": "#/$defs/eval_task_spec"
        }
      }
    },
    "eval_task_spec": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "prompt"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "fixture_type": {
          "type": "string"
        },
        "requires_model_execution": {
          "type": "boolean"
        },
        "artifact_verification": {
          "type": "object"
        },
        "allowed_tools": {
          "$ref": "#/$defs/string_list"
        },
        "max_turns": {
          "type": "integer",
          "minimum": 1
        },
        "expected_artifacts": {
          "$ref": "#/$defs/string_list"
        },
        "required_evidence_sources": {
          "$ref": "#/$defs/string_list"
        },
        "requirements": {
          "$ref": "#/$defs/string_list"
        },
        "requirement_criteria": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "quality_gates": {
          "$ref": "#/$defs/string_list"
        },
        "require_verified_final": {
          "type": "boolean"
        },
        "required_tools": {
          "$ref": "#/$defs/string_list"
        },
        "forbidden_tools": {
          "$ref": "#/$defs/string_list"
        },
        "required_tool_order": {
          "$ref": "#/$defs/string_list"
        },
        "required_tool_arguments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/required_tool_argument"
          }
        },
        "max_duplicate_tool_calls": {
          "$ref": "#/$defs/non_negative_integer_or_null"
        },
        "max_invalid_tool_calls": {
          "$ref": "#/$defs/non_negative_integer_or_null"
        },
        "max_policy_blocks": {
          "$ref": "#/$defs/non_negative_integer_or_null"
        },
        "max_evidence_resolution_failures": {
          "$ref": "#/$defs/non_negative_integer_or_null"
        },
        "max_schema_violations": {
          "$ref": "#/$defs/non_negative_integer_or_null"
        },
        "min_schema_repair_successes": {
          "$ref": "#/$defs/non_negative_integer_or_null"
        },
        "max_schema_repair_failures": {
          "$ref": "#/$defs/non_negative_integer_or_null"
        },
        "allow_recovered_schema_failures": {
          "type": "boolean"
        },
        "min_schema_repair_hint_successes": {
          "$ref": "#/$defs/non_negative_integer_or_null"
        },
        "max_schema_repair_hint_failures": {
          "$ref": "#/$defs/non_negative_integer_or_null"
        },
        "min_tool_repair_successes": {
          "$ref": "#/$defs/non_negative_integer_or_null"
        },
        "max_tool_repair_failures": {
          "$ref": "#/$defs/non_negative_integer_or_null"
        },
        "allow_recovered_tool_failures": {
          "type": "boolean"
        },
        "max_retry_budget_exhaustions": {
          "$ref": "#/$defs/non_negative_integer_or_null"
        },
        "max_pre_dispatch_blocks": {
          "$ref": "#/$defs/non_negative_integer_or_null"
        },
        "required_failure_shape_keys": {
          "$ref": "#/$defs/string_list"
        },
        "forbidden_failure_shape_keys": {
          "$ref": "#/$defs/string_list"
        },
        "max_failure_shape_key_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "required_tool_argument": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tool": {
          "type": "string"
        },
        "tool_name": {
          "type": "string"
        },
        "arguments": {
          "type": "object"
        },
        "args": {
          "type": "object"
        }
      }
    },
    "string_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_negative_integer_or_null": {
      "type": ["integer", "null"],
      "minimum": 0
    }
  },
  "x-metis": {
    "schema_kind": "eval_suite",
    "schema_version": "1",
    "supported_schema_versions": ["1"],
    "predicate_keys": ["contains", "endswith", "equals", "in", "startswith"]
  }
}
